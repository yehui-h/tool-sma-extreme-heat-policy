# Required: enables Mapbox Search Box suggest API for Home Location autocomplete.
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_public_token

# Home risk data source mode: `api` (default) or `mock`.
VITE_HOME_DATA_SOURCE=api

# Required when `VITE_HOME_DATA_SOURCE=api`: backend risk API base URL.
# Ignored when `VITE_HOME_DATA_SOURCE=mock`.
VITE_API_BASE_URL=http://localhost:8000
